    ##  This option is mutually exclusive and takes precedence over all other blocking functions.
    ## ===========================================
    set static::DOH_BLOCKING_BASIC 0

    ## ===========================================
    ## User-Defined Array :: BLACKHOLE CATEGORY BLOCKING: Use this array to include any URL categories to trigger a DoH/DNS blackhole.
    ##  A DNS blackhole sends a valid (but bad) address to the client in response. In this implementation, and IPv4 request
    ##  gets 199.199.199.199, and an IPv6 requests gets 0:0:0:0:0:ffff:c7c7:c7c7.
    ##  Note: if a category exists in both DOH_BLACKHOLE_BY_CATEGORY and DOH_SINKHOLE_BY_CATEGORY, the former takes precedence
    ##
    ##  Actions (select one of these for each anomaly condition):
    ##      - dryrun        --> Dry Run action (just log)
    ##      - blackhole     --> Blackhole the response
    ## ===========================================
    set static::DOH_BLACKHOLE_BY_CATEGORY_ACTION "dryrun"
    set static::DOH_BLACKHOLE_BY_CATEGORY {
        # /Common/Information_Technology1
    }

    ## ===========================================
    ## User-Defined Array :: SINKHOLE CATEGORY BLOCKING: Use this array to include any URL categories to trigger a DoH/DNS sinkhole.
    ##  A DNS sinkhole sends a valid address that points to a local blocking page.
    ##  Note: if a category exists in both DOH_BLACKHOLE_BY_CATEGORY and DOH_SINKHOLE_BY_CATEGORY, the former takes precedence
    ##
    ##  Actions (select one of these for each anomaly condition):
    ##      - dryrun        --> Dry Run action (just log)
    ##      - sinkhole      --> Sinkhole the response
    ## ===========================================
    set static::DOH_SINKHOLE_BY_CATEGORY_ACTION "dryrun"
    set static::DOH_SINKHOLE_BY_CATEGORY {
        #/Common/Entertainment1
    }

    ## ===========================================
    ## User-defined Setting: SINKHOLE IP ADDRESS: This IP address points to an HTTPS VIP on this BIG-IP that will serve up a
    ##  blocking page.
    ## ===========================================
    set static::DOH_SINKHOLE_IP4 "10.1.10.160"
    set static::DOH_SINKHOLE_IP6 "2002:c7c7:c7c8::"

    ## ===========================================
    ## User-defined Settings: ECH_BLOCK: Encrypted Client Hello (ECH) management: Used to detect and block ECH
    ## Ref: https://datatracker.ietf.org/doc/rfc9849/
    ##  ECH defines an extension to TLS1.3 to create two SNI values in the TLS client Hello (inner:encrypted, outer:plaintext). While this adds a layer
    ##  of obfuscation security to TLS communications, it effectively blinds local security systems from knowing the actual SNI target, also breaking URL 
    ##  categorization, SNI-based load balancing and visibility, etc. ECH works by utilizing DNS-over-HTTPS to convey symmetric key information via HTTPS 
    ##  type DNS records. Once the client has this key material, it uses that to encrypt the inner SNI in the TLS Client Hello. The typical resolution to
    ##  this challenge is to disable ECH (prevent the client from getting the ECH key). ECH can generally be disabled in one of two ways:
    ##      a) Blocking all HTTPS record type queries --> light overhead in the parsing of the decrypted HTTP request, but potentially also blocks beneficial 
    ##         values in those records that are used to speed up negotiations (ie. alpn, ipv4hint, ipv6hint)
    ##      b) Removing the "ech" key from HTTPS type query responses --> slightly heavier overhead in the parsing of the DoH decrypted HTTP response, but
    ##         retains beneficial HTTPS record values
    ## ECH_BLOCK takes one of three values:
    ##  - none          --> do not block ECH (default)
    ##  - block         --> block HTTPS record queries
    ##  - echstrip      --> strip the ECH value from HTTPS record responses
    set static::ECH_BLOCK "none"
    ## ===========================================

    ## ===========================================
