    ## ===========================================
    set static::DOH_ANOMALY_CONDITION_UNCOMMON_TYPE_ACTION "dryrun"
    set static::DOH_ANOMALY_CONDITION_UNCOMMON_TYPE {"NULL" "NAPTR"}



    ##############################################
    ## INTERNAL ##################################
    ##############################################

    ## DNS CODES
